generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id               String    @id @default(uuid())
  name             String
  token            String    @unique
  status           String    @default("offline")
  deleted          Boolean   @default(false)
  lastSeen         DateTime?
  ipAddress        String?
  androidVersion   String?
  cpuUsage         Float?    @default(0)
  ramUsed          Float?    @default(0)
  ramTotal         Float?    @default(0)
  storageFree      Float?    @default(0)
  storageTotal     Float?    @default(0)
  screenWidth      Int?      @default(1080)
  screenHeight     Int?      @default(1920)
  onlineSince      DateTime?
  clipboard        String?   @db.Text
  logs             Log[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  level     String   @default("info")
  message   String   @db.Text
  createdAt DateTime @default(now())
}
